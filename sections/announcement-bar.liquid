<div class="announcement-bar-wrapper color-{{ section.settings.color_scheme }} gradient {% if section.settings.page_full_width %} page-full-width {% else %} page-width {% endif %} {% if section.settings.page_full_width_spacing %} page-full-width_spacing {% endif %}">
  <div class="row">
    {% if section.blocks.size > 0 %}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'announcement' -%}
            <div class="announcement-bar" role="region" aria-label="{{ 'sections.header.announcement' | t }}" {{ block.shopify_attributes }}>
              {%- if block.settings.text != blank -%}
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
                {%- endif -%}
                  <p class="announcement-bar__message h5">
                    {{ block.settings.text | escape }}
                    {%- if block.settings.link != blank -%}
                      {% render 'icon-arrow' %}
                    {%- endif -%}
                  </p>
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>

            <div class="top_menu">
              {%- if section.settings.menu != blank -%}
                <ul class="announcement-bar_menu list-menu--inline">
                  {%- for link in section.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {% endif %}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      <a class="btn-close announcement-bar_close" id="close__btn">
        {% render 'icon-close' %}
      </a>
    {% endif %}
  </div>
</div>

{%- style -%}
  /* 🔒 HIDE ANNOUNCEMENT BAR COMPLETELY */
 #shopify-section-announcement-bar {
  display: none !important;
}

  .announcement-bar-wrapper .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 6rem;
    border-bottom: 1px solid #ECEBE7;
  }

  .announcement-bar_close {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer !important;
  }

  .announcement-bar__message {
    padding: 0;
    font-family: var(--font-body-family);
    font-weight: 400;
  }

  .announcement-bar-wrapper {
    position: relative;
  }

  .announcement-bar-wrapper .list-menu--inline {
    margin: 0;
    column-gap: 5rem;
  }

  .announcement-bar-wrapper .list-menu--inline .list-menu__item--link {
    padding: 0;
    font-size: 1.4rem;
  }
{%- endstyle -%}

<script>
  // Script kept for future use (bar is hidden via CSS)
  if (!$.cookie('marquee__cookie')) $(".section__announcement-bar").hide();

  $("#close__btn").click(function () {
    $.cookie('marquee__cookie', 'true', { expires: 1 });
    $(".section__announcement-bar").fadeOut("slow");
    return false;
  });
</script> 





{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-bar",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
